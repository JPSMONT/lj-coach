 "wind_climatology": {
  "summary": "Zugersee is small, light and fickle — average ~3 kt (gusting ~6), prevailing WSW. Reading pressure and the local geography (the Chiemen narrows split the lake into Untersee and Obersee) matters more than boat speed. The good breezes are Bise (NE), West/WSW, and Föhn (S).",
  "patterns": [
   {
    "name": "Bise",
    "dir": "NE (down the long axis)",
    "when": "cold high-pressure NE; the classic working breeze",
    "character": "Channels down the NE–SW axis and ACCELERATES through the Chiemen narrows into the Obersee. Steady, shifts on cycles.",
    "tactics": "Stay in the corridor down the axis; the broad Untersee holds the cleanest Bise; expect a lift / pressure bump at the narrows."
   },
   {
    "name": "West / WSW",
    "dir": "W–SW (prevailing)",
    "when": "the prevailing wind; clean off the flat open NW (Cham)",
    "character": "Clean in the Untersee. In the Obersee the Rigi casts a wind shadow over the west (Immensee) shore.",
    "tactics": "Untersee: anywhere clean. Obersee: favour mid-lake / east side for pressure; avoid parking under the Rigi on the W shore."
   },
   {
    "name": "Föhn",
    "dir": "S / SE fall-wind",
    "when": "föhn conditions; warm, strong, gusty",
    "character": "Hits the Obersee (south) first and hardest over the Rossberg/Rigi gap toward Arth/Immensee.",
    "tactics": "The south end (Arth/Obersee) has the breeze; the Untersee is usually lighter. Reef early; respect the gusts."
   },
   {
    "name": "Thermal / lake breeze",
    "dir": "variable",
    "when": "sunny light days — the most common mode (~3 kt avg)",
    "character": "Hills heat vs the lake and drive an afternoon breeze; evenings fill from the Obersee.",
    "tactics": "Follow the building breeze, often mid-lake; it strengthens through the afternoon. An evening beat south from Immensee can pay (YCI)."
   }
  ]
 },
 "tactical_zones": [
  {
   "name": "Untersee (north basin, Cham↔Zug)",
   "knowledge": "Broad (up to 4.6 km), flat, no mountains on the NW side — the cleanest, most open wind. Best for Bise and West/WSW."
  },
  {
   "name": "Chiemen narrows (mid-lake)",
   "knowledge": "~1 km constriction by the wooded Chiemen peninsula. Wind accelerates and shifts here — \"good for surprises\" (YCI). The Goldschäkel sits right at this transition."
  },
  {
   "name": "Obersee (south basin, Immensee↔Arth)",
   "knowledge": "Deep, mountain-framed (Rigi W/SW, Rossberg S, Zugerberg E). Sheltered, shifty, gusty; Föhn-exposed; a Rigi wind-shadow on the W (Immensee) shore."
  }
 ],
